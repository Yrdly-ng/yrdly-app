{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/auto-release",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-event-payouts",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/unread-notifications",
      "schedule": "0 10 * * *"
    }
  ]
}
